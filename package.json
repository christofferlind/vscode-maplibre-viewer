{
  "name": "vscode-maplibre-viewer",
  "displayName": "vscode-maplibre-viewer",
  "description": "MapLibre Viewer",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "maps-container",
          "title": "Maps",
          "icon": "resources/map-icon.svg"
        }
      ]
    },
    "views": {
      "maps-container": [
        {
          "id": "mapsView",
          "name": "Maps",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "MapLibre Viewer",
      "properties": {
        "vscodeMaplibreViewer.mapStyleUrl": {
          "type": "string",
          "default": "https://demotiles.maplibre.org/style.json",
          "description": "URL to the MapLibre style.json file for the map display"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run copy-assets",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "copy-assets": "node scripts/copy-maplibre-assets.js"
  },
  "dependencies": {
    "maplibre-gl": "^4.7.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
