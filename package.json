{
  "name": "vscode-maplibre-viewer",
  "displayName": "vscode-maplibre-viewer",
  "description": "MapLibre Viewer",
  "version": "0.5.0",
  "repository": {
    "type": "github",
    "url": "https://github.com/christofferlind/vscode-maplibre-viewer"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:mapsView"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "maps-container",
          "title": "Maps",
          "icon": "resources/map-icon.svg"
        }
      ]
    },
    "views": {
      "maps-container": [
        {
          "id": "mapsView",
          "name": "Maps",
          "type": "webview"
        },
        {
          "id": "layersView",
          "name": "Map Layers"
        },
        {
          "id": "bookmarksView",
          "name": "Map Bookmarks"
        }
      ]
    },
    "commands": [
      {
        "command": "vscodeMaplibreViewer.setLanguageNative",
        "title": "Map: Set Language to Native",
        "category": "MapLibre Viewer"
      },
      {
        "command": "vscodeMaplibreViewer.setLanguageEnglish",
        "title": "Map: Set Language to English",
        "category": "MapLibre Viewer"
      },
      {
        "command": "vscodeMaplibreViewer.setLanguageGerman",
        "title": "Map: Set Language to German",
        "category": "MapLibre Viewer"
      },
      {
        "command": "vscodeMaplibreViewer.setLanguage",
        "title": "Map: Set Language...",
        "category": "MapLibre Viewer",
        "icon": "$(inspect)"
      },
      {
        "command": "vscodeMaplibreViewer.toggleCoordinateSelection",
        "title": "Toggle Coordinate Selection",
        "category": "MapLibre Viewer"
      },
      {
        "command": "vscodeMaplibreViewer.enableCoordinateSelection",
        "title": "Enable Coordinate Selection",
        "category": "MapLibre Viewer",
        "icon": "$(sync)"
      },
      {
        "command": "vscodeMaplibreViewer.disableCoordinateSelection",
        "title": "Disable Coordinate Selection",
        "category": "MapLibre Viewer",
        "icon": "$(sync-ignored)"
      },
      {
        "command": "vscodeMaplibreViewer.openSettings",
        "title": "Open Map Settings",
        "category": "MapLibre Viewer",
        "icon": "$(gear)"
      },
      {
        "command": "vscodeMaplibreViewer.saveBookmark",
        "title": "Map: Bookmark Current View",
        "category": "MapLibre Viewer",
        "icon": "$(bookmark)"
      },
      {
        "command": "vscodeMaplibreViewer.loadBookmark",
        "title": "Map: Load Bookmark...",
        "category": "MapLibre Viewer"
      },
      {
        "command": "vscodeMaplibreViewer.goToBookmark",
        "title": "Go to Bookmark",
        "category": "MapLibre Viewer",
        "icon": "$(location)"
      },
      {
        "command": "vscodeMaplibreViewer.deleteBookmark",
        "title": "Delete Bookmark",
        "category": "MapLibre Viewer",
        "icon": "$(trash)"
      },
      {
        "command": "vscodeMaplibreViewer.setBaseMap",
        "title": "Set Active Base Map",
        "category": "MapLibre Viewer"
      },
      {
        "command": "vscodeMaplibreViewer.toggleLayer",
        "title": "Toggle Layer Visibility",
        "category": "MapLibre Viewer"
      },
      {
        "command": "vscodeMaplibreViewer.addLayer",
        "title": "Add Overlay Layer",
        "category": "MapLibre Viewer",
        "icon": "$(add)"
      },
      {
        "command": "vscodeMaplibreViewer.removeLayer",
        "title": "Remove Layer",
        "category": "MapLibre Viewer",
        "icon": "$(trash)"
      },
      {
        "command": "vscodeMaplibreViewer.searchOnMap",
        "title": "Search On Map",
        "category": "MapLibre Viewer"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "vscodeMaplibreViewer.setLanguage",
          "when": "view == mapsView",
          "group": "1_languages"
        },
        {
          "command": "vscodeMaplibreViewer.enableCoordinateSelection",
          "when": "view == mapsView && maplibreView.coordinateSelectionEnabled == false",
          "group": "2_coordinates"
        },
        {
          "command": "vscodeMaplibreViewer.disableCoordinateSelection",
          "when": "view == mapsView && maplibreView.coordinateSelectionEnabled == true",
          "group": "2_coordinates"
        },
        {
          "command": "vscodeMaplibreViewer.saveBookmark",
          "when": "view == mapsView",
          "group": "navigation@1"
        },
        {
          "command": "vscodeMaplibreViewer.openSettings",
          "when": "view == mapsView",
          "group": "navigation@2"
        },
        {
          "command": "vscodeMaplibreViewer.addLayer",
          "when": "view == layersView",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "vscodeMaplibreViewer.deleteBookmark",
          "when": "view == bookmarksView && viewItem == bookmark",
          "group": "bookmarkActions"
        },
        {
          "command": "vscodeMaplibreViewer.removeLayer",
          "when": "view == layersView && viewItem == visibleOverlayLayer",
          "group": "layerActions"
        },
        {
          "command": "vscodeMaplibreViewer.removeLayer",
          "when": "view == layersView && viewItem == overlayLayer",
          "group": "layerActions"
        }
      ],
      "editor/context": [
        {
          "command": "vscodeMaplibreViewer.searchOnMap",
          "when": "editorHasSelection",
          "group": "navigation"
        }
      ],
      "terminal/context": [
        {
          "command": "vscodeMaplibreViewer.searchOnMap",
          "when": "terminalFocus",
          "group": "1_search"
        }
      ]
    },
    "configuration": {
      "title": "MapLibre Viewer",
      "properties": {
        "vscodeMaplibreViewer.geocodingApiKey": {
          "type": "string",
          "default": "",
          "description": "API key for geocoding service (MapTiler)"
        },
        "vscodeMaplibreViewer.photonSearchUrl": {
          "type": "string",
          "default": "https://photon.komoot.io/api/",
          "description": "URL for Photon geocoding search service (used when MapTiler API key is not configured)"
        },
        "vscodeMaplibreViewer.enableSearch": {
          "type": "boolean",
          "default": true,
          "description": "Enable search functionality in the map view"
        },
        "vscodeMaplibreViewer.flyToDuration": {
          "type": "number",
          "default": 500,
          "description": "Duration in milliseconds for flyTo animations when navigating to coordinates"
        },
        "vscodeMaplibreViewer.singlePointZoom": {
          "type": "number",
          "default": 10,
          "description": "Zoom level to use when flying to a single coordinate point"
        },
        "vscodeMaplibreViewer.baseMaps": {
          "type": "array",
          "default": [],
          "description": "Custom basemap styles available in the layer selector. Each basemap requires an id, name, and either styleUrl (for vector styles) or tileUrl (for raster tiles).",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Unique identifier for the basemap"
              },
              "name": {
                "type": "string",
                "description": "Display name shown in the layer selector"
              },
              "type": {
                "type": "string",
                "enum": ["vector", "raster"],
                "description": "Type of basemap: 'vector' for style JSON, 'raster' for raster tiles. Defaults to 'vector' if styleUrl is provided."
              },
              "styleUrl": {
                "type": "string",
                "description": "URL to the MapLibre style JSON (for vector basemaps)"
              },
              "tileUrl": {
                "type": "string",
                "description": "Raster tile URL template with {z}/{x}/{y} placeholders (e.g., 'https://tile.example.com/{z}/{x}/{y}.png')"
              },
              "tileSize": {
                "type": "number",
                "default": 256,
                "description": "Tile size for raster sources (default: 256)"
              },
              "attribution": {
                "type": "string",
                "description": "Attribution text for the tiles"
              },
              "minzoom": {
                "type": "number",
                "description": "Minimum zoom level for raster tiles"
              },
              "maxzoom": {
                "type": "number",
                "description": "Maximum zoom level for raster tiles"
              },
              "description": {
                "type": "string",
                "description": "Optional description of the basemap"
              },
              "thumbnail": {
                "type": "string",
                "description": "Optional thumbnail image URL for the basemap"
              }
            },
            "required": ["id", "name"]
          }
        },
        "vscodeMaplibreViewer.coordinatePatterns": {
          "type": "array",
          "default": [],
          "description": "Custom regex patterns for coordinate detection. Each pattern must have named groups 'lat' and 'lng' for direct coordinate extraction, or DMS component groups (latDegrees, latMinutes, latSeconds, latDirection, lngDegrees, lngMinutes, lngSeconds, lngDirection).",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "A descriptive name for the pattern (e.g., 'Swedish Grid')"
              },
              "pattern": {
                "type": "string",
                "description": "The regex pattern string. Must include named groups 'lat' and 'lng'. Example: 'X:\\s*(?<lng>\\d+)\\s*,\\s*Y:\\s*(?<lat>\\d+)'"
              },
              "flags": {
                "type": "string",
                "default": "g",
                "description": "Regex flags (e.g., 'g' for global, 'i' for case-insensitive). Default is 'g'."
              }
            },
            "required": ["name", "pattern"]
          }
        },
        "vscodeMaplibreViewer.lastViewState": {
          "type": "object",
          "default": {
            "center": { "lat": 0, "lng": 0 },
            "zoom": 1,
            "bearing": 0,
            "pitch": 0,
            "baseMapId": "maplibre-demotiles"
          },
          "description": "Last saved map view state (center, zoom, bearing, pitch, baseMapId). Automatically updated when the map view changes.",
          "properties": {
            "center": {
              "type": "object",
              "properties": {
                "lat": { "type": "number" },
                "lng": { "type": "number" }
              }
            },
            "zoom": { "type": "number" },
            "bearing": { "type": "number" },
            "pitch": { "type": "number" },
            "baseMapId": {
              "type": "string",
              "description": "ID of the last selected base map"
            }
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run copy-assets",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "test": "npm run compile && mocha --ui tdd out/test/unit/**/*.test.js",
    "test:vscode": "npm run compile && npm run lint && npx @vscode/test-cli",
    "copy-assets": "node scripts/copy-maplibre-assets.js",
    "package": "vsce package"
  },
  "dependencies": {
    "maplibre-gl": "^4.7.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.0.0",
    "eslint": "^9.39.3",
    "mocha": "^11.7.5",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.56.1"
  }
}
